<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Menú raíz -->
    <menuitem id="menu_discrepancy_root"
              name="Discrepancias"
              sequence="15"/>

    <!-- Acción -->
    <record id="action_discrepancy_log" model="ir.actions.act_window">
        <field name="name">Gestión de Discrepancias</field>
        <field name="res_model">discrepancy.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Registra discrepancias con evidencia, autorízalas y corrige inventario sin detener la operación.</p>
        </field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_discrepancy_log"
              name="Bitácora"
              parent="menu_discrepancy_root"
              action="action_discrepancy_log"
              sequence="25"/>

    <!-- Vista lista -->
    <record id="view_discrepancy_log_list" model="ir.ui.view">
        <field name="name">discrepancy.log.list</field>
        <field name="model">discrepancy.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="picking_id"/>
                <field name="measurement_mode" widget="badge"
                       decoration-info="measurement_mode == 'kg'"
                       decoration-success="measurement_mode == 'pcs'"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Vista formulario -->
    <record id="view_discrepancy_log_form" model="ir.ui.view">
        <field name="name">discrepancy.log.form</field>
        <field name="model">discrepancy.log</field>
        <field name="arch" type="xml">
            <form string="Discrepancia de Recepción">

                <header>
                    <button name="action_submit" type="object" string="Enviar"
                            invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Autorizar"
                            invisible="state != 'to_approve'"/>
                    <button name="action_apply_correction" type="object" string="Aplicar corrección"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" type="object" string="Cancelar"
                            invisible="state in ('corrected', 'cancelled')"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,to_approve,approved,corrected,cancelled"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="picking_id"
                                   domain="[('state', 'not in', ('cancel', 'done'))]"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="measurement_mode"
                                   widget="radio"
                                   options="{'horizontal': true}"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group>
                        <field name="description" placeholder="Motivo de la discrepancia…" nolabel="1"/>
                    </group>

                    <notebook>

                        <!-- DETALLE -->
                        <page string="Detalle">
                            <field name="line_ids" mode="list,form">

                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="expected_qty"
                                           string="Esperada"/>
                                    <field name="received_qty"
                                           string="Recibida"/>
                                    <field name="difference_qty" readonly="1"
                                           string="Diferencia"/>
                                    <field name="unit_label" readonly="1" string="Unidad"/>
                                    <field name="product_uom" optional="hide"/>
                                    <field name="measurement_mode" optional="hide"/>
                                </list>

                                <form>
                                    <group>
                                        <field name="product_id"/>
                                        <field name="expected_qty"/>
                                        <field name="received_qty"/>
                                        <field name="difference_qty" readonly="1"/>
                                        <field name="unit_label" readonly="1"/>
                                        <field name="product_uom"/>
                                    </group>
                                </form>

                            </field>
                        </page>

                        <!-- EVIDENCIA -->
                        <page string="Evidencia">
                            <field name="evidence_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="image_1920" widget="image"
                                           options="{'size': [90, 90]}"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="image_1920" widget="image"/>
                                    </group>
                                </form>
                            </field>
                        </page>

                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban imágenes -->
    <record id="view_discrepancy_image_kanban" model="ir.ui.view">
        <field name="name">discrepancy.image.kanban</field>
        <field name="model">discrepancy.image</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="image_1920"
                                       widget="image"
                                       class="o_image_128"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong><field name="name"/></strong>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>